# --- Supabase Postgres (Session Pooler) ---
DB_URL=jdbc:postgresql://aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres
DB_USERNAME=postgres.zzukpubwbntihzztilqy
DB_PASSWORD=

# --- JWT (15 phút - Access ; 7 ngày - Refresh)---
JWT_SECRET=
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# --- Redis (docker-compose local) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Mail (Gmail SMTP - App Password) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_APP_PASSWORD=
MAIL_FROM=
OTP_EXPIRATION_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# --- Google OAuth2 ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Cookie ---
# true khi deploy production (HTTPS), false khi chay local (http://localhost)
COOKIE_SECURE=false

# --- DOMAIN ---
FRONTEND_DOMAIN=*