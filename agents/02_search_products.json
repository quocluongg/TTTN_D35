                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Extract Vector": {
            "main": [
                [
                    {
                        "node": "Vector Search (Supabase RPC)",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Vector Search (Supabase RPC)": {
            "main": [
                [
                    {
                        "node": "LLM Answer (GPT-4o-mini)",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "LLM Answer (GPT-4o-mini)": {
            "main": [
                [
                    {
                        "node": "Format Response",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Format Response": {
            "main": [
                [
                    {
                        "node": "Respond to Webhook",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        }
    },
    "settings": {
        "executionOrder": "v1",
        "saveExecutionProgress": true,
        "timezone": "UTC"
    },
    "staticData": null,
    "tags": [
        {
            "name": "rag"
        },
        {
            "name": "query"
        }
    ],
    "active": false
}